private def codeIndex (x : SevenVertexEdgeCode) : Nat :=
  Nat.bit (x e01) <| Nat.bit (x e02) <| Nat.bit (x e03) <|
  Nat.bit (x e04) <| Nat.bit (x e05) <| Nat.bit (x e06) <|
  Nat.bit (x e12) <| Nat.bit (x e13) <| Nat.bit (x e14) <|
  Nat.bit (x e15) <| Nat.bit (x e16) <| Nat.bit (x e23) <|
  Nat.bit (x e24) <| Nat.bit (x e25) <| Nat.bit (x e26) <|
  Nat.bit (x e34) <| Nat.bit (x e35) <| Nat.bit (x e36) <|
  Nat.bit (x e45) <| Nat.bit (x e46) <| Nat.bit (x e56) 0

private def certEdgeIndex (e : SevenVertexEdge) : Nat :=
  if e = e01 then 0 else if e = e02 then 1 else if e = e03 then 2 else
  if e = e04 then 3 else if e = e05 then 4 else if e = e06 then 5 else
  if e = e12 then 6 else if e = e13 then 7 else if e = e14 then 8 else
  if e = e15 then 9 else if e = e16 then 10 else if e = e23 then 11 else
  if e = e24 then 12 else if e = e25 then 13 else if e = e26 then 14 else
  if e = e34 then 15 else if e = e35 then 16 else if e = e36 then 17 else
  if e = e45 then 18 else if e = e46 then 19 else 20

private def codeOfNat (m : Nat) : SevenVertexEdgeCode :=
  fun e => Nat.testBit m (certEdgeIndex e)

