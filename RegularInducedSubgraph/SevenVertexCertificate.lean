private def certWitnessChoiceOfNat (m : Nat) : Nat :=
  (String.Pos.Raw.get certSevenVertexWitnessTable ⟨m⟩).toNat - 35

private def certWitnessMaskOfNat (m : Nat) : Fin 128 :=
  certSevenVertexWitnessMasks.getD (certWitnessChoiceOfNat m) ⟨15, by decide⟩

private def maskMem (mask : Fin 128) (v : Fin 7) : Bool :=
  decide ((mask.1 / 2 ^ v.1) % 2 = 1)

private theorem maskMem_eq_decide_mem_decide :
    decide (∀ mask : Fin 128, ∀ v : Fin 7,
      maskMem mask v = decide (v ∈ sevenVertexFinsetOfMask mask)) = true := by
  native_decide

private lemma maskMem_eq_decide_mem (mask : Fin 128) (v : Fin 7) :
    maskMem mask v = decide (v ∈ sevenVertexFinsetOfMask mask) := by
  exact of_decide_eq_true maskMem_eq_decide_mem_decide mask v

private def degreeWitness (x : SevenVertexEdgeCode) (mask : Fin 128) (v : Fin 7) : Nat :=
  sevenVertexCodeDegree x (sevenVertexFinsetOfMask mask) v

private def regularWitnessVertices (x : SevenVertexEdgeCode) (mask : Fin 128) : Bool :=
  match (List.finRange 7).filter (maskMem mask) with
  | [] => true
  | v :: vs => vs.all fun w => decide (degreeWitness x mask w = degreeWitness x mask v)

private def witnessFastBoolOfNat (m : Nat) : Bool :=
  let mask := certWitnessMaskOfNat m
  let c := (sevenVertexFinsetOfMask mask).card
  decide (c = 4 ∨ c = 5) && regularWitnessVertices (codeOfNat m) mask

private def allWitnessFastNat : Bool :=
  (List.range 2097152).all witnessFastBoolOfNat

private theorem allWitnessFastNat_true : allWitnessFastNat = true := by
  native_decide

private lemma bit_lt_two_pow_succ {n k : Nat} (h : n < 2 ^ k) (b : Bool) :
    Nat.bit b n < 2 ^ (k + 1) := by
  rw [Nat.pow_succ]
  cases b <;> simp [Nat.bit]
  · nlinarith [h]
  · nlinarith [h]

private lemma codeIndex_lt (x : SevenVertexEdgeCode) : codeIndex x < 2097152 := by
  change codeIndex x < 2 ^ 21
  unfold codeIndex
  repeat apply bit_lt_two_pow_succ
  norm_num

private lemma regularWitnessVertices_sound {x : SevenVertexEdgeCode} {mask : Fin 128}
    (hreg : regularWitnessVertices x mask = true) :
    sevenVertexCodeRegular x (sevenVertexFinsetOfMask mask) = true := by
  let verts := (List.finRange 7).filter (maskMem mask)
  change (match verts with
    | [] => true
    | v :: vs => vs.all fun w => decide (degreeWitness x mask w = degreeWitness x mask v)) = true at hreg
  unfold sevenVertexCodeRegular
  rw [List.all_eq_true]
  intro v _hv
  rw [List.all_eq_true]
  intro w _hw
  apply decide_eq_true
  intro hv hw
  have hvMem : v ∈ verts := by
    dsimp [verts]
    rw [List.mem_filter]
    refine ⟨List.mem_finRange v, ?_⟩
    rw [maskMem_eq_decide_mem]
    exact decide_eq_true hv
  have hwMem : w ∈ verts := by
    dsimp [verts]
    rw [List.mem_filter]
    refine ⟨List.mem_finRange w, ?_⟩
    rw [maskMem_eq_decide_mem]
    exact decide_eq_true hw
  cases hverts : verts with
  | nil =>
      rw [hverts] at hvMem
      simp at hvMem
  | cons v₀ vs =>
      rw [hverts] at hreg
      have hall : ∀ y ∈ vs, degreeWitness x mask y = degreeWitness x mask v₀ := by
        simpa [List.all_eq_true] using hreg
      have hvEq : degreeWitness x mask v = degreeWitness x mask v₀ := by
        rw [hverts] at hvMem
        rcases (List.mem_cons.mp hvMem) with hv0 | hvrest
        · rw [hv0]
        · exact hall v hvrest
      have hwEq : degreeWitness x mask w = degreeWitness x mask v₀ := by
        rw [hverts] at hwMem
        rcases (List.mem_cons.mp hwMem) with hw0 | hwrest
        · rw [hw0]
        · exact hall w hwrest
      simpa [degreeWitness] using hvEq.trans hwEq.symm

private lemma witnessFastBoolOfNat_sound {m : Nat}
    (h : witnessFastBoolOfNat m = true) :
    sevenVertexCodeHasRegularFourOrFiveBool (codeOfNat m) = true := by
  let mask := certWitnessMaskOfNat m
  have hparts :
      decide ((sevenVertexFinsetOfMask mask).card = 4 ∨
          (sevenVertexFinsetOfMask mask).card = 5) = true ∧
        regularWitnessVertices (codeOfNat m) mask = true := by
    simpa [witnessFastBoolOfNat, mask] using h
  have hcard : (sevenVertexFinsetOfMask mask).card = 4 ∨
      (sevenVertexFinsetOfMask mask).card = 5 := of_decide_eq_true hparts.1
  have hreg : sevenVertexCodeRegular (codeOfNat m) (sevenVertexFinsetOfMask mask) = true :=
    regularWitnessVertices_sound hparts.2
  unfold sevenVertexCodeHasRegularFourOrFiveBool
  rw [List.any_eq_true]
  refine ⟨mask, by simp, ?_⟩
  simp [hcard, hreg]

private lemma witnessFastBoolOfNat_of_lt {m : Nat} (hm : m < 2097152) :
    witnessFastBoolOfNat m = true := by
  have hall : ∀ n ∈ List.range 2097152, witnessFastBoolOfNat n = true := by
    simpa [allWitnessFastNat, List.all_eq_true] using allWitnessFastNat_true
  exact hall m (List.mem_range.mpr hm)

theorem sevenVertexFourOrFiveBoolCertificate :
    ∀ x : SevenVertexEdgeCode, sevenVertexCodeHasRegularFourOrFiveBool x = true := by
  intro x
  have hfast : witnessFastBoolOfNat (codeIndex x) = true :=
    witnessFastBoolOfNat_of_lt (codeIndex_lt x)
  have hsound : sevenVertexCodeHasRegularFourOrFiveBool (codeOfNat (codeIndex x)) = true :=
    witnessFastBoolOfNat_sound hfast
  simpa [code_roundtrip x] using hsound

theorem sevenVertexFourRegularBaseCase : SevenVertexFourRegularBaseCase :=
  sevenVertexFourRegularBaseCase_of_boolCertificate sevenVertexFourOrFiveBoolCertificate

end RegularInducedSubgraph
