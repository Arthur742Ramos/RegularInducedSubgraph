    {u v : α} (huv_ne : u ≠ v) (huv : ¬ G.Adj u v) (hdegv : G.degree v = 13) :
    3 ≤ (((Finset.univ.erase v).filter (fun w => ¬ G.Adj v w)).erase u |>.filter
