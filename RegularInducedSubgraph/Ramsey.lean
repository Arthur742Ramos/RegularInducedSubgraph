      ramseyThreeEightDegreeWindow_residual_degree_seven_common_neighbor_sum_eq_forty_two_forces_neighbor_degree_seven
        (G := G) (s := s) hdegree hnoK3 (v := v) hdegv hsumEq (w := w) hw hvw
