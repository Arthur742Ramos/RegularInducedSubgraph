  degree_mem_Icc_of_card_twenty_six_no_clique_four_no_indep_five G hcard
    hasCliqueOrIndepSetBound_three_five_fourteen
    hasCliqueOrIndepSetBound_four_four_eighteen hnoK4 hnoI5 v

