  have hsum :
      G.degree u =
        (G.neighborFinset u ∩ G.neighborFinset v).card +
          (((Finset.univ.erase v).filter (fun w => ¬ G.Adj v w)).erase u |>.filter
            (G.Adj u)).card :=
    degree_eq_neighbor_inter_neighborFinset_add_neighbor_in_nonNeighborFinset_of_nonadjacent
      G huv
  constructor
  · exact hN
  constructor
  · omega
  constructor
  · exact hM
  · omega

