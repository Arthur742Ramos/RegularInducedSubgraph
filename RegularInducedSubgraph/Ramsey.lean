    common_neighbor_card_eq_four_of_degree_thirteen_no_clique_four_no_indep_five
      G hnoK4 hnoI5 huv hdegv
  have hdegBounds :=
    degree_mem_Icc_of_card_twenty_seven_no_clique_four_no_indep_five_unconditional
      G hcard hnoK4 hnoI5 u
  have hsplit :=
