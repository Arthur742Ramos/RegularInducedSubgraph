  exact HasCliqueOrIndepSetBound.step_mono (a := 2) (b := 6)
    (N₁ := 7) (N₂ := 19) (N := 26)
    (by decide) (by decide) h27 hasCliqueOrIndepSetBound_three_six_nineteen
