        intro w hw
        have hwCross := htCross hw
        exact (Finset.mem_filter.mp hwCross).2)⟩
    · rintro ⟨t, htCross, htIndep⟩
      exact hnoI5 ⟨insert v t, by
        rw [← SimpleGraph.isNClique_compl] at htIndep ⊢
        refine htIndep.insert ?_
        intro w hw
