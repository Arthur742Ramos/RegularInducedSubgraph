theorem neighbor_in_nonNeighborFinset_card_le_eight
    {α : Type} [Fintype α] [DecidableEq α] (G : SimpleGraph α) [DecidableRel G.Adj]
    (hnoK4 : ¬ ∃ t : Finset α, G.IsNClique 4 t)
    (hnoI5 : ¬ ∃ t : Finset α, G.IsNIndepSet 5 t)
    {u v : α} :
