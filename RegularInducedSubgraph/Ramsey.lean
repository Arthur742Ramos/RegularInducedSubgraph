-/
theorem adjacent_common_neighbor_card_le_forty_one_of_3_10_42_no_clique_five_no_indep_ten
    {α : Type} [DecidableEq α] (h3_10 : HasCliqueOrIndepSetBound 3 10 42)
    (G : SimpleGraph α) (s : Finset α)
    (hnoK5 : ¬ ∃ t ⊆ s, G.IsNClique 5 t)
