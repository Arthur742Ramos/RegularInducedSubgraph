    (((s.erase (v : α)).erase x).filter
      (fun w => G.Adj (v : α) w ∧ G.Adj x w)).card
  have hnonNbrsCard : nonNbrsV.card = 27 := by
    simpa [nonNbrsV] using
      ramseyThreeNineRegular8_residual_nonNeighbor_card_eq_twenty_seven
