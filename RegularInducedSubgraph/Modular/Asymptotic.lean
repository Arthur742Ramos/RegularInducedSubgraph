  have hprod : 384 ≤ (2 ^ j) ^ C * 6 := by
    simpa using Nat.mul_le_mul_right 6 hpowSixtyFour
  have hn : 384 ≤ n := by
    exact le_trans (le_trans hprod hs) (by simpa using (Finset.card_le_univ s))
