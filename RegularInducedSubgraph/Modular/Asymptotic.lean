def HasPolynomialCostFixedWitnessRegularSubbucketSelection (D : ℕ) : Prop :=
  ∀ {n j : ℕ} (G : SimpleGraph (Fin n)) {S : Finset (Fin n)},
    ((2 ^ j) ^ D * 2 ^ j) ≤ S.card →
      InducesModEqDegree G S (2 ^ j) →
        ∃ u : Finset (Fin n), u ⊆ S ∧ u.card = 2 ^ j ∧
          ∃ d : ℕ, InducesRegularOfDegree G u d

