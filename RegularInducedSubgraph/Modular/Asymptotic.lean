          Q64FRSatExchangeCompleteSmallerQMarker
              (frsatComplex hj G hhost).completeSupports.saturate
              (frsatRow hj G hhost) ∨
          PrimeModuleExit hj G hhost ∨
          (Q64FRSatPrefixLocalFailure
              (frsatComplex hj G hhost).completeSupports.saturate
              (frsatRow hj G hhost) ∨
            Q64FRSatNonzeroFirstTerminalResidue
              (frsatComplex hj G hhost).completeSupports.saturate
