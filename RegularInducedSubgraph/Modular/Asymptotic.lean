        FullySkewSplitter hj G hhost →
          (frsatComplex hj G hhost).completeSupports.saturate.splitter
            (frsatRow hj G hhost))
    (completeSmallerCloses :
      ∀ {n j : ℕ} (hj : 0 < j) (G : SimpleGraph (Fin n))
