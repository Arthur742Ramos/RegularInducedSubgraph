    (Row :
      ∀ {n j : ℕ}, 0 < j → (G : SimpleGraph (Fin n)) →
        HasBoundedFixedModulusControlBlockModularHostWitnessOfCard G (2 ^ j) (2 ^ j) r →
          Type uRoute)
    (Packet :
