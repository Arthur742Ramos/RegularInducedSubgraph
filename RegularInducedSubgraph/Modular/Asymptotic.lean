        PrimeModuleExit hj G hhost ∨
        (Q64FRSatPrefixLocalFailure
            (q64ProofMdFRSatTerminalRawExchangeComplex hj G hhost).completeSupports.saturate
            (frsatRow hj G hhost) ∨
