def HasPolynomialCostFixedWitnessRegularSubbucketSelectionFiveFromSeven : Prop :=
  ∀ {n j : ℕ} (hj : 7 ≤ j) (G : SimpleGraph (Fin n)) {S : Finset (Fin n)},
