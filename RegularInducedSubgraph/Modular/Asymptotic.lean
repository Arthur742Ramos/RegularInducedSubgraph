  · intro n j hj G hhost
    exact
      { splitter := fun _ => False
        prefixLocal := fun _ => True
        terminalResidue := fun _ => 0
        support := fun _ => ∅
        exchangeComplete := fun _ => False }
  · intro n j hj G hhost
    exact PUnit.unit
  · intro n j hj G hhost _hconstant
