  rcases hloss G (by simpa using hsmod) with ⟨t, hts, hlosscard, htmod⟩
  refine ⟨t, ?_, ?_⟩
  · have h64 : 64 * m ≤ s.card := by
      simpa using hs
    have hbound : 64 * m ≤ 64 * t.card := le_trans h64 hlosscard
    omega
  · simpa using htmod

