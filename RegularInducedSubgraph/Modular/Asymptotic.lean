lemma hasFixedModulusControlBlockModularCascadeWitnessOfCard_of_dyadicLift
    {C n r m : ℕ} (hr : 0 < r) (hbase : DyadicParityBaseCase)
    (hlift : HasPolynomialCostDyadicLift C) (hsize : dyadicLiftVertexCost C r * m ≤ n)
    (G : SimpleGraph (Fin n)) :
