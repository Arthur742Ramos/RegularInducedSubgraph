    {n : ℕ} (G : SimpleGraph (Fin n)) :
    HasFixedModulusWitnessOfCard G ((2 ^ 4) ^ 6 * 2 ^ 4) (2 ^ 4) →
      HasRegularInducedSubgraphOfCard G (2 ^ 4) := by
  exact fixedWitnessTerminalRegularizationData_six_of_le_four (by norm_num) G

