    {D : ℕ}
    {CarrierMarkerCoupling PrimeCycleBreaker SignLaw OneCornerLift CompensatorRouting
      GlobalBridge : Prop}
    (hchain :
      Q64FinalAuditComponentChain CarrierMarkerCoupling PrimeCycleBreaker SignLaw OneCornerLift
        CompensatorRouting
