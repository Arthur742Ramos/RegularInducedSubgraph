-/
def HasExactCardFixedSingleControlHostDroppedPartUpgrade : Prop :=
  ∀ {n j : ℕ} (G : SimpleGraph (Fin n)),
    HasExactCardFixedModulusSingleControlModularHostWitnessOfCard G (2 ^ j) (2 ^ j) →
