  ∀ M : ℕ, ∃ K : ℕ, ∀ ⦃k : ℕ⦄, K ≤ k →
    ∀ G : SimpleGraph (Fin (b ^ k)),
      HasBoundedControlBlockModularBucketingWitnessOfCard G (M * k) (r k)

