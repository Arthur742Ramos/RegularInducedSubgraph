      (dyadicObstructionCut_of_nonconstantResidue := ?_)
      (qMarker_of_dyadicObstructionCut := ?_)
      (qMarkerLocalClosuresOrFullySkew := ?_)
      (fullySkewToCompletedFRSatSplitter := ?_)
      (completeSmallerCloses := ?_)
