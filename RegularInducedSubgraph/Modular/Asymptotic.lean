      exact le_trans hpow (Nat.pow_le_pow_right (by decide : 0 < 2) hquadratic)
    have hkF : 2 ^ r ≤ F (2 ^ k) := by
      exact le_F_of_forcingThreshold_le hthreshold
    rw [le_F_iff] at hkF
    rcases hkF G with ⟨s, hs, d, hsreg⟩
    exact ⟨s, le_trans hsize hs, d, hsreg⟩

