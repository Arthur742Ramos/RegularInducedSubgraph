      | succ r =>
          let m' : ℕ := (2 ^ (r + 1)) ^ C * m
          have hprev : dyadicLiftVertexCost C (r + 1) * m' ≤ n := by
            dsimp [m']
            simpa [dyadicLiftVertexCost, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm] using hsize
