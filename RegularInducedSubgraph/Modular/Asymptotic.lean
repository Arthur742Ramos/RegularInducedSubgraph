            (frsatComplex hj G hhost).completeSupports.saturate
            (frsatRow hj G hhost) →
          RegularQSet hj G hhost)
    (primeModuleCloses :
      ∀ {n j : ℕ} (hj : 0 < j) (G : SimpleGraph (Fin n))
        (hhost : HasBoundedFixedModulusControlBlockModularHostWitnessOfCard G (2 ^ j) (2 ^ j) r),
