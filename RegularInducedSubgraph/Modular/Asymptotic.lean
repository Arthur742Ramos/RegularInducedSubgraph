  have hdrop :
      HasDroppedTailModEqSubbucketForBoundedFixedModulusControlBlockModularHostWitnessOfCard
        G (2 ^ j) (2 ^ j) r := by
    exact Classical.byContradiction (by
      simpa [Q64DroppedTailNonconstantResidue] using hconstant)
