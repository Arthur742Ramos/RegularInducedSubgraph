def coreSize : PositiveAtomPostQuotientFiniteCoreSelector → ℕ
  | sizeFourBaseTriple => 4
  | sizeFourStar => 4
  | sizeThreePath => 3
  | sizeThreeK3 => 3
  | sizeTwoAdjacent => 2
  | sizeTwoDisjoint => 2

