    (TwoDisjointTemplatesNeedTwo : Prop)
    {α : Type} [DecidableEq α] (G : SimpleGraph α) (s : Finset α)
    (v : ↑(s : Set α))
    (sizeRefinedAtoms defectCorrection unionAntiCancellation principalBucketShadowFrontier : Prop)
