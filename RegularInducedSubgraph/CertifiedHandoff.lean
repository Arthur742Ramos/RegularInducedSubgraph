    (AnchoredPacking : Type*) (TraceTwinFree : AnchoredPacking → Prop)
    (packingSize : AnchoredPacking → ℕ)
    (WitnessCountAtLeast : ℕ → ℕ → Prop)
    (TwoDisjointTemplatesNeedTwo : Prop)
