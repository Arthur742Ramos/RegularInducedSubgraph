      sizeRefinedAtoms defectCorrection unionAntiCancellation
      principalBucketShadowFrontier
  packetAtomFrontier :
    FirstBitTerminalPacketAtomFrontierImports
      sizeRefinedAtoms defectCorrection unionAntiCancellation
  packetAtomShadow :
    FirstBitTerminalPacketAtomPrincipalBucketShadowImports
      (FirstBitTerminalPacketAtomFrontierImports
        sizeRefinedAtoms defectCorrection unionAntiCancellation)
      principalBucketShadowFrontier

